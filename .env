# Dev defaults — no secrets here. Override in .env.local for real deployments.
# Postgres runs via docker-compose (`docker compose up -d db`); this URL matches
# the compose service. In production point it at your managed Postgres.
DATABASE_URL="postgresql://atexili:atexili@localhost:5432/atexili?schema=public"
JWT_SECRET="atexili-dev-secret-change-in-production"

# S3 photo/document storage (optional).
# Leave unset and the app falls back to gradient placeholder photos.
# Works with AWS S3 or any S3-compatible service (Cloudflare R2, MinIO, Spaces).
# S3_BUCKET="atexili-uploads"
# S3_REGION="eu-central-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""            # set for S3-compatible providers (R2/MinIO/Spaces)
# S3_PUBLIC_URL=""          # CDN / public read base; defaults to the bucket URL
# S3_FORCE_PATH_STYLE=""    # "true" for MinIO
